rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the user
    //   - items: list (required) - List of order items
    //   - total: number (required) - Total order amount
    //   - status: string (required) - Enum: pending, confirmed, delivering, delivered, cancelled
    //   - createdAt: timestamp (required) - Time of creation
    //   - customerInfo: map (required) - Name, email, phone, address
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "georgedrake03303@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt', 'customerInfo']) &&
             data.userId is string &&
             data.items is list &&
             data.total is number &&
             data.status in ['pending', 'confirmed', 'delivering', 'delivered', 'cancelled'] &&
             data.createdAt is timestamp &&
             data.customerInfo is map &&
             data.customerInfo.keys().hasAll(['name', 'email', 'phone', 'address']);
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && (isOwner(request.resource.data.userId) || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAdmin();
    }
  }
}
