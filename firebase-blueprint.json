{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A customer's order for food items.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who placed the order."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          },
          "description": "The items in the order."
        },
        "total": {
          "type": "number",
          "description": "The total amount of the order."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "confirmed", "delivering", "delivered", "cancelled"],
          "description": "The current status of the order."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the order was placed."
        },
        "customerInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        }
      },
      "required": ["userId", "items", "total", "status", "createdAt", "customerInfo"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    }
  }
}
