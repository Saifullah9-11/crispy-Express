{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A customer's order for food items.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who placed the order."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          },
          "description": "The items in the order."
        },
        "total": {
          "type": "number",
          "description": "The total amount of the order."
        },
        "deliveryType": {
          "type": "string",
          "enum": ["delivery", "pickup"],
          "description": "Whether the order is for delivery or pickup."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "preparing", "on-way", "delivered", "cancelled"],
          "description": "The current status of the order."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the order was placed."
        },
        "customerInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        }
      },
      "required": ["userId", "items", "total", "deliveryType", "status", "createdAt", "customerInfo"]
    },
    "User": {
      "title": "User",
      "description": "A registered user of the application.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user."
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the user."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The role of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user was registered."
        }
      },
      "required": ["name", "role", "createdAt"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User shopping cart items",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of registered users."
    },
    "/carts/{userId}": {
      "schema": "Cart",
      "description": "User shopping carts."
    }
  }
}
